<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Solo el buscador hasta arriba -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <EditText
            android:id="@+id/editTextMemberId"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="ID Miembro"
            android:inputType="number"
            android:imeOptions="actionSearch"
            android:maxLines="1"
            android:padding="12dp"
            android:background="@android:drawable/edit_text" />

        <Button
            android:id="@+id/buttonSearch"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Buscar"
            android:padding="12dp"
            android:layout_marginStart="8dp" />

    </LinearLayout>

    <!-- Nombre del miembro encontrado -->
    <TextView
        android:id="@+id/textViewMemberName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/primary_color"
        android:layout_marginTop="8dp"
        android:visibility="gone" />

    <!-- Lista de resultados -->
    <ListView
        android:id="@+id/listViewAssignments"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="16dp" />

    <!-- Mensaje cuando no hay resultados -->
    <TextView
        android:id="@+id/textViewEmpty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Sin resultados"
        android:textSize="14sp"
        android:layout_gravity="center"
        android:layout_marginTop="32dp"
        android:visibility="visible" />

</LinearLayout>
